<s_paging>
  <!-- 페이지네이션 -->
  <div>
    <!-- 이전 페이지 -->
    <a [##_prev_page_##] class="[##_no_more_prev_##]"> 이전 </a>
    <!-- 페이지 번호들 -->
    <div>
      <s_paging_rep>
        <!-- 페이지 번호 -->
        <a [##_paging_rep_link_##]>[##_paging_rep_link_num_##]</a>
      </s_paging_rep>
    </div>
    <!-- 다음 페이지 -->
    <a [##_next_page_##] class="[##_no_more_next_##]">다음</a>
  </div>
  <!-- 더보기 -->
  <div>
    <a [##_more_link_##]>
      <p>더보기</p>
    </a>
  </div>
</s_paging>
