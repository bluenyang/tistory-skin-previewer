<s_list>
  <div>
    <!-- 리스트의 아이템 -->
    <s_list_rep>
      <div>
        <a href="[##_article_prev_link_##]">
          <div>
            <s_list_rep_thumbnail>
              <img
                loading="lazy"
                src="[##_list_rep_thumbnail_##]"
              />
            </s_list_rep_thumbnail>
          </div>
          <div>
            <h3>
              [##_list_rep_title_text_##]
            </h3>
            <span>
              [##_list_rep_summary_##]
            </span>
            <span>
              [##_list_rep_regdate_##]
            </span>
          </div>
        </a>
      </div>
    </s_list_rep>
  </div>
</s_list>
