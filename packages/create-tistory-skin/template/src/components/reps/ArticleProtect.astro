<!-- 보호된 글의 대체 화면압니다. -->
<s_article_protected>
  <s_permalink_article_rep>
    <p>
      보호되어 있는 글입니다.
      <br />
      내용을 보시려면 비밀번호를 입력하세요.
    </p>

    <!-- 보호된 글을 보기위한 비밀번호 입력 폼입니다. -->
    <form onsubmit=`[##_article_dissolve_##]`>
      <div>
        <input
          type="password"
          id="[##_article_password_##]"
          name="[##_article_password_##]"
          value=""
          placeholder="비밀번호"
        />
        <button type="submit">확인</button>
      </div>
    </form>
  </s_permalink_article_rep>
</s_article_protected>
